DISCORD_TOKEN=your_bot_token_here

# 테스트 중에는 서버 ID를 넣으면 슬래시 명령어가 해당 서버들에 바로 등록됩니다.
# 여러 서버는 쉼표로 구분합니다. 비워두면 전역 명령어로 등록됩니다.
GUILD_IDS=1386716926516133949,1279685629751459902

# 추가로 AutoMod 예외 처리할 역할 ID를 쉼표로 구분해 넣을 수 있습니다.
# Discord는 Administrator / Manage Server 권한 보유자를 AutoMod에서 기본 예외 처리합니다.
EXTRA_EXEMPT_ROLE_IDS=

# Ticket Tool 채널을 자동으로 /멘션차단 목록에 추가합니다.
# 권장: 티켓 채널이 생성되는 카테고리 ID를 넣으세요.
AUTO_BLOCK_CATEGORY_IDS=

# 카테고리 대신 채널 이름 prefix로 잡고 싶을 때 씁니다.
# 예: ticket-,티켓-,문의-
AUTO_BLOCK_CHANNEL_NAME_PREFIXES=ticket-,티켓-

# true로 두면 새로 생기는 모든 텍스트/공지/포럼/미디어/음성 채널을 차단 대상에 넣습니다.
# 보통은 너무 강하므로 false 권장입니다.
AUTO_BLOCK_NEW_CHANNELS=false
